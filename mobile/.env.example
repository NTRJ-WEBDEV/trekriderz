# Environment variables for TrekRiderz Mobile (Expo)

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Mapbox Configuration
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Payment Gateway (Razorpay)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# AI Services
DEEPSEEK_API_KEY=sk_xxx
OPENAI_API_KEY=your_openai_key_here
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_key_here   # Fallback image moderation (used only if Gemini key below is absent)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_key_here   # Preferred AI moderation (text + image) — free tier at aistudio.google.com

# Business Contact (used for WhatsApp booking links — no spaces, include country code)
EXPO_PUBLIC_BUSINESS_WHATSAPP=91XXXXXXXXXX

# App Configuration
APP_ENV=development
NODE_ENV=development
