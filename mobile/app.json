{
  "expo": {
    "name": "TrekRiderz",
    "slug": "trekriderz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "trekriderz",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trekriderz.app",
      "associatedDomains": [
        "applinks:trekriderz.app"
      ]
    },
    "android": {
      "package": "com.trekriderz.app",

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "trekriderz"
            },
            {
              "scheme": "https",
              "host": "trekriderz.app",
              "pathPrefix": "/trip"
            },
            {
              "scheme": "https",
              "host": "trekriderz.app",
              "pathPrefix": "/post"
            },
            {
              "scheme": "https",
              "host": "trekriderz.app",
              "pathPrefix": "/user"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "946b44e9-cee5-4d14-93c3-0492cbb2dd9f"
      }
    },
    "owner": "ntrj_webdev"
  }
}
